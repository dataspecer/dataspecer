{
  "name": "@dataspecer/app-generator",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "compile-assets": "node scripts/compile-assets.mjs",
    "build": "tsc",
    "dev": "tsc -w",
    "prebuild": "rimraf lib && npm run compile-assets --silent",
    "predev": "npm run compile-assets --silent",
    "pretest": "npm run compile-assets --silent",
    "prelint": "npm run compile-assets --silent",
    "test": "vitest run --pass-with-no-tests",
    "lint": "eslint . && prettier . --check",
    "lint:fix": "eslint . --fix && prettier . --write"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "eta": "^4.6.0"
  },
  "exports": {
    ".": "./lib/index.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "ldkit": "^2.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.6"
  }
}
